# Server
PORT=5001
NODE_ENV=development

# Auth
JWT_SECRET=change-me-in-production
OTP_TTL_MINUTES=10
DEFAULT_WALLET_BALANCE=500

# Option A: Local PostgreSQL
DB_USER=postgres
DB_HOST=localhost
DB_NAME=agrodealer
DB_PORT=5432
DB_PASSWORD=your_local_postgres_password
DB_SSL=false

# Option B: Neon PostgreSQL (recommended for cloud dev)
# If DATABASE_URL is set, it is used instead of DB_USER/DB_HOST/DB_NAME/DB_PORT/DB_PASSWORD.
# Example: postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=
